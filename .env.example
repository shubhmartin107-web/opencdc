# OpenCDC Environment Configuration
# Copy this file to .env and update values for your local setup.

# Logging
RUST_LOG=info

# PostgreSQL Connector (optional)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=postgres
PG_USER=postgres
PG_PASSWORD=postgres
PG_PUBLICATION=opencdc_pub
PG_SLOT=opencdc_slot

# MySQL Connector (optional)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=mydb
MYSQL_USER=cdc_user
MYSQL_PASSWORD=cdc_pass

# MongoDB Connector (optional)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=mydb

# Schema Registry (optional)
SCHEMA_REGISTRY_URL=http://localhost:8081

# OpenLake REST Catalog
OPENLAKE_URL=http://localhost:8080
OPENLAKE_PREFIX=v1
OPENLAKE_NAMESPACE=default
